# ============================================================
# Tower Scan Automation - Variables de Entorno (EJEMPLO)
# ============================================================
# Copiar este archivo como .env y ajustar los valores.
# Este archivo es la FUENTE ÚNICA DE VERDAD para la configuración.
# ============================================================

# --- Flask ---
FLASK_APP=app.web_app
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# --- Red / Servidor ---
HOST=0.0.0.0
PORT=5000

# --- Parámetros de Escaneo (defaults para la UI) ---
# Comunidades SNMP separadas por coma. Se prueban en orden hasta encontrar
# la que responde para cada dispositivo.
SNMP_COMMUNITIES=Canopy

# Target Receive Level en dBm (nivel de señal objetivo del radio)
DEFAULT_TARGET_RX_LEVEL=-52

# SNR mínimo aceptable en dB
DEFAULT_MIN_SNR=32

# Diferencia máxima de polarización en dB
DEFAULT_MAX_POLARIZATION_DIFF=5

# Ancho de canal por defecto en MHz (5, 10, 15, 20, 30, 40)
DEFAULT_CHANNEL_WIDTH=20

# --- cnMaestro API (obligatorio para importar inventario) ---
CNMAESTRO_URL=https://your-cnmaestro-host/api/v1
CNMAESTRO_ID=your-client-id
CNMAESTRO_SECRET=your-client-secret
