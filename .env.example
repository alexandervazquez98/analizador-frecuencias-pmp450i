# Configuración de la aplicación
FLASK_APP=app.web_app
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Parámetros por defecto
DEFAULT_SNMP_COMMUNITY=Canopy
DEFAULT_TARGET_RECEIVE_LEVEL=-52
DEFAULT_MIN_SNR=32
DEFAULT_MAX_POLARIZATION_DIFF=5

# Configuración de red
HOST=0.0.0.0
PORT=5000

# cnMaestro API (obligatorio para inventario)
CNMAESTRO_URL=https://your-cnmaestro-host/api/v1
CNMAESTRO_ID=your-client-id
CNMAESTRO_SECRET=your-client-secret
